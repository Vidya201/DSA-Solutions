class Solution(object):
    def lengthOfLongestSubstring(self, s):
        """
        :type s: str
        :rtype: int
        """
        result=""
        c=0
        j=0
        for i in range(len(s)):
            if s[i] not in result and j<i:
                result+=s[i]
                c+=1
                j+=1
        return c
        
