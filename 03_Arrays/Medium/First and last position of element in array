class Solution(object):
    def searchRange(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        indices=-1
        l=[]
        for num in nums:
            indices+=1
            if num==target:
                l.append(indices)
                
        if not l:
            return [-1,-1]

        return l[0],l[-1]
